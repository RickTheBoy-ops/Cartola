# ====================================================================
# CARTOLA FC OPTIMIZER - Variáveis de Ambiente
# ====================================================================
# Copie este arquivo para .env e preencha os valores
# O arquivo .env NUNCA deve ser commitado no repositório (já está no .gitignore)
# ====================================================================

# --- Conta Cartola FC (opcional, para login autenticado) ---
CARTOLA_EMAIL=
CARTOLA_PASSWORD=

# --- Configurações do Otimizador ---
CARTOLA_ORCAMENTO=110
CARTOLA_FORMACAO=
CARTOLA_MODO=equilibrado

# --- The Odds API ---
# Chave gratuita disponível em: https://the-odds-api.com
# Plano free: 500 requisições/mês — suficiente para todas as rodadas
# Sem esta chave, o sistema usa probabilidades calculadas pelo histórico interno
ODDS_API_KEY=sua_chave_aqui

# --- APIs Legadas (não obrigatórias) ---
RAPIDAPI_KEY=
PERPLEXITY_API_KEY=
